{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Gospeak",
  "version": "0.1.0",
  "identifier": "com.gospeak.alpha",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Gospeak",
        "width": 1180,
        "height": 760,
        "minWidth": 1024,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false
      },
      {
        "label": "recorder",
        "title": "Gospeak Recorder",
        "width": 148,
        "height": 36,
        "resizable": false,
        "fullscreen": false,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "shortDescription": "Local-first AI voice input for Windows",
    "longDescription": "Gospeak records speech, uses the explicitly selected local or cloud ASR and rewrite providers, and pastes into the active application without cross-provider fallback.",
    "publisher": "Gospeak",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
